{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@apmicro/ui/*": [
        "packages/ui/src/*"
      ],
      "@apmicro/ui": [
        "packages/ui/src/index.ts"
      ],
      "@apmicro/shared-types/*": [
        "packages/shared-types/src/*"
      ],
      "@apmicro/shared-types": [
        "packages/shared-types/src/index.ts"
      ],
      "@apmicro/content-core/*": [
        "packages/content-core/src/*"
      ],
      "@apmicro/content-core": [
        "packages/content-core/src/index.ts"
      ],
      "@apmicro/graph-engine/*": [
        "packages/graph-engine/src/*"
      ],
      "@apmicro/graph-engine": [
        "packages/graph-engine/src/index.ts"
      ]
    }
  }
}
